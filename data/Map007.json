{"id":3,"name":"EV003","note":"","pages":[{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":false,"switch1Id":3,"switch1Valid":false,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":false,"image":{"tileId":0,"characterName":"director","direction":2,"pattern":1,"characterIndex":0},"list":[{"code":101,"indent":0,"parameters":["director",0,0,2]},{"code":401,"indent":0,"parameters":["Director Joe: Estoy algo ocupado ahora vuelve más tarde."]},{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":1,"stepAnime":false,"through":false,"trigger":0,"walkAnime":true},{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":false,"switch1Id":3,"switch1Valid":true,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":false,"image":{"tileId":0,"characterName":"director","direction":2,"pattern":1,"characterIndex":0},"list":[{"code":205,"indent":0,"parameters":[3,{"list":[{"code":25,"indent":null},{"code":0}],"repeat":false,"skippable":false,"wait":true}]},{"code":505,"indent":0,"parameters":[{"code":25,"indent":null}]},{"code":101,"indent":0,"parameters":["director",0,0,2]},{"code":401,"indent":0,"parameters":["Director Joe: Buenas mis queridos estudiantes."]},{"code":101,"indent":0,"parameters":["director",0,0,2]},{"code":401,"indent":0,"parameters":["Director Joe: ¿Que los trae a mi oficina?"]},{"code":101,"indent":0,"parameters":["pedro",0,0,2]},{"code":401,"indent":0,"parameters":["Cody: Queremos comentarle un problema de nuestro compañero."]},{"code":101,"indent":0,"parameters":["juana",0,0,2]},{"code":401,"indent":0,"parameters":["Julia: Más especificamente una situación de Leo."]},{"code":101,"indent":0,"parameters":["antonio",0,0,2]},{"code":401,"indent":0,"parameters":["Leo: ..."]},{"code":101,"indent":0,"parameters":["antonio",0,0,2]},{"code":401,"indent":0,"parameters":["Leo: Lo que sucede es que he tenido varios conflictos"]},{"code":401,"indent":0,"parameters":["con algunos de mis compañeros."]},{"code":101,"indent":0,"parameters":["antonio",0,0,2]},{"code":401,"indent":0,"parameters":["Leo: Me han estado excluyendo y creando rumores falsos sobre mi."]},{"code":101,"indent":0,"parameters":["director",0,0,2]},{"code":401,"indent":0,"parameters":["Director Joe: ¿En serio? Debiste avisarme antes, no puedo"]},{"code":401,"indent":0,"parameters":["permitir tales conductas en mi institución."]},{"code":101,"indent":0,"parameters":["antonio",0,0,2]},{"code":401,"indent":0,"parameters":["Leo: Se me hacia dificil comentarlo, hasta que Cody y Julia..."]},{"code":101,"indent":0,"parameters":["antonio",0,0,2]},{"code":401,"indent":0,"parameters":["Leo: Me dieron valor de afrontarlo."]},{"code":101,"indent":0,"parameters":["director",0,0,2]},{"code":401,"indent":0,"parameters":["Director Joe: Necesito que me cuentes a detalle los involucrados."]},{"code":101,"indent":0,"parameters":["antonio",0,0,2]},{"code":401,"indent":0,"parameters":["Leo: Principalmente fue Brayan, siempre me trata mal cuando puede."]},{"code":101,"indent":0,"parameters":["antonio",0,0,2]},{"code":401,"indent":0,"parameters":["Leo: Me aterra tratar con él, pero, no quiero que nos llevemos mal."]},{"code":101,"indent":0,"parameters":["director",0,0,2]},{"code":401,"indent":0,"parameters":["Director Joe: Gracias por contarme, voy a hablar con él."]},{"code":101,"indent":0,"parameters":["antonio",0,0,2]},{"code":401,"indent":0,"parameters":["Leo: No es nada..."]},{"code":101,"indent":0,"parameters":["juana",0,0,2]},{"code":401,"indent":0,"parameters":["Julia: Muchas gracias."]},{"code":101,"indent":0,"parameters":["pedro",0,0,2]},{"code":401,"indent":0,"parameters":["Cody: Busquemos a Brayan."]},{"code":121,"indent":0,"parameters":[4,4,0]},{"code":121,"indent":0,"parameters":[3,3,1]},{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":1,"stepAnime":false,"through":false,"trigger":0,"walkAnime":true},{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":false,"switch1Id":6,"switch1Valid":true,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":false,"image":{"tileId":0,"characterName":"director","direction":2,"pattern":1,"characterIndex":0},"list":[{"code":241,"indent":0,"parameters":[{"name":"Final","volume":50,"pitch":100,"pan":0}]},{"code":101,"indent":0,"parameters":["director",0,0,2]},{"code":401,"indent":0,"parameters":["Director Joe: Chicos, ¿Pueden explicar que sucedio?"]},{"code":101,"indent":0,"parameters":["director",0,0,2]},{"code":401,"indent":0,"parameters":["Director Joe: Saben que pelear es una falta muy grave."]},{"code":101,"indent":0,"parameters":["pedro",0,0,2]},{"code":401,"indent":0,"parameters":["Cody: Después de contarle lo que paso, Brayan nos busco pelea."]},{"code":101,"indent":0,"parameters":["pedro",0,0,2]},{"code":401,"indent":0,"parameters":["Cody: Intente decirle que se calme, pero, era tarde."]},{"code":101,"indent":0,"parameters":["juana",0,0,2]},{"code":401,"indent":0,"parameters":["Julia: Leo de cosa y se puede levantar..."]},{"code":101,"indent":0,"parameters":["Brayan",0,0,2]},{"code":401,"indent":0,"parameters":["Brayan: Solo les di lo que merecian."]},{"code":101,"indent":0,"parameters":["director",0,0,2]},{"code":401,"indent":0,"parameters":["Director Joe: Brayan... debes ser empatico con los demás"]},{"code":401,"indent":0,"parameters":["tu conducta va en contra de los valores de la institución."]},{"code":101,"indent":0,"parameters":["Brayan",0,0,2]},{"code":401,"indent":0,"parameters":["Brayan: ¿Por qué lo debería ser con estas basuras?"]},{"code":101,"indent":0,"parameters":["maestra",0,0,2]},{"code":401,"indent":0,"parameters":["Maestra: Si todos te excluyeran, te despreciaran e inventaran"]},{"code":401,"indent":0,"parameters":["rumores sobre ti, ¿Te sentirías bien?"]},{"code":101,"indent":0,"parameters":["Brayan",0,0,2]},{"code":401,"indent":0,"parameters":["Brayan: Me dan igual, ¿Qué importa eso?"]},{"code":101,"indent":0,"parameters":["juana",0,0,2]},{"code":401,"indent":0,"parameters":["Julia: Pues no estabas muy feliz con lo que supuestamente"]},{"code":401,"indent":0,"parameters":["dijo Leo, ¿A que no?"]},{"code":101,"indent":0,"parameters":["Brayan",0,0,2]},{"code":401,"indent":0,"parameters":["Brayan: Tsk, es diferente, no soporto a ese idiota."]},{"code":101,"indent":0,"parameters":["antonio",0,0,2]},{"code":401,"indent":0,"parameters":["Leo: Ah..."]},{"code":101,"indent":0,"parameters":["director",0,0,2]},{"code":401,"indent":0,"parameters":["Director Joe: ¿Qué te ha hecho él para que le tengas tanto resentimiento?"]},{"code":101,"indent":0,"parameters":["Brayan",0,0,2]},{"code":401,"indent":0,"parameters":["Brayan: Nada, solo no lo soporto."]},{"code":101,"indent":0,"parameters":["director",0,0,2]},{"code":401,"indent":0,"parameters":["Director Joe: Es un pesar tu actitud, debí darme cuenta antes"]},{"code":401,"indent":0,"parameters":["de esta situación..."]},{"code":101,"indent":0,"parameters":["director",0,0,2]},{"code":401,"indent":0,"parameters":["Director Joe: Ni siquiera puedes cumplir con uno de nuestros"]},{"code":401,"indent":0,"parameters":["valores más básicos como lo es la empatia."]},{"code":101,"indent":0,"parameters":["director",0,0,2]},{"code":401,"indent":0,"parameters":["Director Joe: No creo que te sentirías muy bien si a un familiar"]},{"code":401,"indent":0,"parameters":["le hacen lo que tú has hecho con Leo, ¿Verdad?"]},{"code":101,"indent":0,"parameters":["Brayan",0,0,2]},{"code":401,"indent":0,"parameters":["Brayan: Yo... creo que no."]},{"code":101,"indent":0,"parameters":["director",0,0,2]},{"code":401,"indent":0,"parameters":["Director Joe: Debes ponerte en el lugar de los demás."]},{"code":101,"indent":0,"parameters":["Brayan",0,0,2]},{"code":401,"indent":0,"parameters":["Brayan: ..."]},{"code":101,"indent":0,"parameters":["director",0,0,2]},{"code":401,"indent":0,"parameters":["Director Joe: Tendrás tu respectivo castigo, ahora pidele disculpas a Leo."]},{"code":101,"indent":0,"parameters":["Brayan",0,0,2]},{"code":401,"indent":0,"parameters":["Brayan: Tsk, yo..."]},{"code":101,"indent":0,"parameters":["Brayan",0,0,2]},{"code":401,"indent":0,"parameters":["Brayan: ..."]},{"code":101,"indent":0,"parameters":["Brayan",0,0,2]},{"code":401,"indent":0,"parameters":["Brayan: Perdón."]},{"code":101,"indent":0,"parameters":["maestra",0,0,2]},{"code":401,"indent":0,"parameters":["Maestra: Espero puedas mejorar tu actitud."]},{"code":101,"indent":0,"parameters":["director",0,0,2]},{"code":401,"indent":0,"parameters":["Director Joe: Ustedes tres también tendrán consecuencias."]},{"code":101,"indent":0,"parameters":["director",0,0,2]},{"code":401,"indent":0,"parameters":["Director Joe: Aun así, me enorgullece que hayan ayudado a su compañero."]},{"code":101,"indent":0,"parameters":["director",0,0,2]},{"code":401,"indent":0,"parameters":["Director Joe: No vuelvan a pelear, espero lo hayan entendido bien."]},{"code":101,"indent":0,"parameters":["pedro",0,0,2]},{"code":401,"indent":0,"parameters":["Cody: Si..."]},{"code":101,"indent":0,"parameters":["antonio",0,0,2]},{"code":401,"indent":0,"parameters":["Leo: Si director."]},{"code":101,"indent":0,"parameters":["juana",0,0,2]},{"code":401,"indent":0,"parameters":["Julia: Más que claro."]},{"code":101,"indent":0,"parameters":["maestra",0,0,2]},{"code":401,"indent":0,"parameters":["Maestra: Dejenme decirle que técnicamente cumplieron con su tarea."]},{"code":101,"indent":0,"parameters":["maestra",0,0,2]},{"code":401,"indent":0,"parameters":["Maestra: Pero tendrán que hacer un exposición conjunta sobre el"]},{"code":401,"indent":0,"parameters":["arrepentimiento y perdón."]},{"code":101,"indent":0,"parameters":["pedro",0,0,2]},{"code":401,"indent":0,"parameters":["Cody: Esta bien maestra. "]},{"code":101,"indent":0,"parameters":["antonio",0,0,2]},{"code":401,"indent":0,"parameters":["Leo: Ok..."]},{"code":101,"indent":0,"parameters":["juana",0,0,2]},{"code":401,"indent":0,"parameters":["Julia: Bueno, podría ser peor."]},{"code":101,"indent":0,"parameters":["Brayan",0,0,2]},{"code":401,"indent":0,"parameters":["Brayan: Que más da."]},{"code":101,"indent":0,"parameters":["director",0,0,2]},{"code":401,"indent":0,"parameters":["Director Joe: Pueden retirarse."]},{"code":101,"indent":0,"parameters":["director",0,0,2]},{"code":401,"indent":0,"parameters":["Director Joe: Y como dijo un sabio alguna vez."]},{"code":101,"indent":0,"parameters":["director",0,0,2]},{"code":401,"indent":0,"parameters":["Director Joe: \"Ser empático es ver el mundo con los ojos del otro,"]},{"code":401,"indent":0,"parameters":[" y no ver nuestro mundo reflejado en los ojos de él\" "]},{"code":401,"indent":0,"parameters":["— Carl Rogers."]},{"code":223,"indent":0,"parameters":[[-255,-255,-255,0],60,false]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["¿Esa es la verdadera empatia?"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["Tal vez..."]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["Pero esta pequeña aventura ya termino."]},{"code":354,"indent":0,"parameters":[]},{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":1,"stepAnime":false,"through":false,"trigger":0,"walkAnime":true}],"x":5,"y":2},
